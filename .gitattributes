# Keep repository text files normalized to LF.
* text=auto eol=lf

# Windows command scripts keep CRLF when checked out.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
